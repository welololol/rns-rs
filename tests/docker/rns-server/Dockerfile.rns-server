FROM rust:1.93.1-bookworm AS builder
WORKDIR /build
ARG RNS_SERVER_FEATURES=rns-hooks
COPY Cargo.toml Cargo.lock ./
COPY build build
COPY rns-crypto rns-crypto
COPY rns-core rns-core
COPY rns-net rns-net
COPY rns-cli rns-cli
COPY rns-ctl rns-ctl
COPY rns-hooks rns-hooks
COPY rns-stats-hook rns-stats-hook
COPY rns-sentinel-hook rns-sentinel-hook
COPY rns-server rns-server
RUN for feature in $RNS_SERVER_FEATURES; do \
      case "$feature" in rns-hooks|rns-hooks-wasm) rustup target add wasm32-unknown-unknown; exit 0 ;; esac; \
    done
RUN cargo build --release --bin rns-server --features "$RNS_SERVER_FEATURES"

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*
COPY --from=builder /build/target/release/rns-server /usr/local/bin/rns-server
RUN mkdir -p /etc/rns /data
EXPOSE 8080
HEALTHCHECK --interval=2s --timeout=2s --retries=30 \
  CMD curl -sf http://localhost:8080/health || exit 1
CMD ["sh", "-c", "cp /etc/rns/config /data/config && exec rns-server start --config /data --disable-auth --http-host 0.0.0.0 --http-port 8080"]
